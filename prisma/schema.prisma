generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id                String            @id @default(nanoid())
  fullName          String
  password          String
  email             String
  username          String?
  parentNumber      String
  group             Group?            @relation(fields: [groupId], references: [id])
  groupId           String?
  homework          Homework[]
  studentActivities StudentActivity[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  submits           Submission[]
}

model Admin {
  id        String   @id @default(nanoid())
  email     String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id          String   @id @default(nanoid())
  title       String
  description String
  pictureUrl  String?
  videoId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  url         String?
}

model Group {
  id        String    @id @default(nanoid())
  name      String
  course    Course?   @relation(fields: [courseId], references: [id])
  courseId  String?
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Course {
  id          String   @id @default(nanoid())
  name        String
  description String
  groups      Group[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Homework {
  id                String           @id @default(nanoid())
  student           Student?         @relation(fields: [studentId], references: [id])
  studentId         String?
  title             String
  description       String
  checked           Boolean          @default(false)
  point             Int?
  deadline          DateTime
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  studentActivity   StudentActivity? @relation(fields: [studentActivityId], references: [id])
  studentActivityId String?
}

model StudentActivity {
  id        String     @id @default(nanoid())
  student   Student?   @relation(fields: [studentId], references: [id])
  studentId String?
  rating    String
  tasks     Homework[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Question {
  id        String   @id @default(nanoid())
  text      String   @map("question")
  points    Int
  options   String[]
  answer    String
  test      Test?    @relation(fields: [testId], references: [id])
  testId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Test {
  id            String       @id @default(nanoid())
  title         String
  questions     Question[]
  allPoints     Int          @default(0)
  scheduledDate DateTime     @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submissions   Submission[]
}

model Submission {
  id        String   @id @default(nanoid())
  student   Student? @relation(fields: [studentId], references: [id])
  studentId String?
  test      Test?    @relation(fields: [testId], references: [id])
  testId    String
  score     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
