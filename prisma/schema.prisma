generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id                String            @id @default(nanoid())
  fullName          String
  password          String
  email             String
  username          String?
  parentNumber      String
  group             Group?            @relation(fields: [groupId], references: [id])
  groupId           String?
  homework          Homework[]
  studentActivities StudentActivity[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  submits           Submission[]
  rating            Int               @default(0)
  level             Difficulty        @default(easy)
  notes             Notes[]
}

model Notes {
  id        String   @id @default(nanoid())
  text      String
  student   Student? @relation(fields: [studentId], references: [id])
  studentId String?
}

model Admin {
  id        String   @id @default(nanoid())
  email     String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id          String   @id @default(nanoid())
  title       String
  description String
  pictureUrl  String?
  videoId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  url         String?
}

model Group {
  id        String    @id @default(nanoid())
  name      String
  course    Course?   @relation(fields: [courseId], references: [id])
  courseId  String?
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Course {
  id          String   @id @default(nanoid())
  name        String
  description String
  groups      Group[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Homework {
  id                String           @id @default(nanoid())
  student           Student?         @relation(fields: [studentId], references: [id])
  studentId         String?
  title             String
  description       String
  checked           Boolean          @default(false)
  point             Int?
  deadline          DateTime
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  studentActivity   StudentActivity? @relation(fields: [studentActivityId], references: [id])
  studentActivityId String?
}

model StudentActivity {
  id        String     @id @default(nanoid())
  student   Student?   @relation(fields: [studentId], references: [id])
  studentId String?
  rating    String
  tasks     Homework[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model QuizSchema {
  id             String       @id @default(nanoid())
  type           QuizTypes
  title          String
  desc           String?
  difficulty     Difficulty
  topic          String
  image          String?
  givenTime      Int
  extraTime      Int
  score          Int
  isDaily        Boolean
  isActive       Boolean
  input          String
  explanation    String
  variants       Variants[]
  submittedUsers Submission[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Variants {
  id           String      @id @default(nanoid())
  option       String
  isTrue       Boolean
  quizSchema   QuizSchema? @relation(fields: [quizSchemaId], references: [id])
  quizSchemaId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Submission {
  id           String      @id @default(nanoid())
  student      Student?    @relation(fields: [studentId], references: [id])
  studentId    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  quizSchema   QuizSchema? @relation(fields: [quizSchemaId], references: [id])
  quizSchemaId String?
}

enum QuizTypes {
  multipleChoice
  bugHunting
  expectedOutput
  missingCode
}

enum Difficulty {
  easy
  medium
  hard
  expert
  master
}
