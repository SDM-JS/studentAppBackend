generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id                String            @id @default(nanoid())
  fullName          String
  password          String
  email             String
  username          String?
  parentNumber      String
  group             Group?            @relation(fields: [groupId], references: [id])
  groupId           String?
  homework          Homework[]
  studentActivities StudentActivity[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model News {
  id          String   @id @default(nanoid())
  title       String
  description String
  pictureUrl  String?
  videoId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  id        String    @id @default(nanoid())
  name      String
  course    Course?   @relation(fields: [courseId], references: [id])
  courseId  String?
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Course {
  id          String   @id @default(nanoid())
  name        String
  description String
  groups      Group[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Homework {
  id                String           @id @default(nanoid())
  student           Student?         @relation(fields: [studentId], references: [id])
  studentId         String?
  title             String
  description       String
  checked           Boolean          @default(false)
  point             Int?
  deadline          DateTime
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  studentActivity   StudentActivity? @relation(fields: [studentActivityId], references: [id])
  studentActivityId String?
}

model StudentActivity {
  id        String     @id @default(nanoid())
  student   Student?   @relation(fields: [studentId], references: [id])
  studentId String?
  rating    String
  tasks     Homework[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
